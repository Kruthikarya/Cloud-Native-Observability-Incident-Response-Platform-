{
  "info": {
    "name": "Cloud Native Observability Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "gateway",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"admin@ops.local\",\"password\":\"admin123\"}"
        },
        "url": "{{gateway}}/api/auth/login"
      }
    },
    {
      "name": "Infrastructure Summary",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{gateway}}/api/monitoring/infra/summary"
      }
    },
    {
      "name": "Kubernetes Pods",
      "request": {
        "method": "GET",
        "url": "{{gateway}}/api/monitoring/kubernetes/pods"
      }
    },
    {
      "name": "Trace Dependencies",
      "request": {
        "method": "GET",
        "url": "{{gateway}}/api/monitoring/traces/dependencies"
      }
    },
    {
      "name": "Evaluate Alert",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"target\":\"prod-api-02\",\"metricName\":\"system.cpu.usage\",\"value\":94.7}"
        },
        "url": "{{gateway}}/api/alerts/evaluate"
      }
    },
    {
      "name": "Alerts",
      "request": {
        "method": "GET",
        "url": "{{gateway}}/api/alerts"
      }
    },
    {
      "name": "Incidents",
      "request": {
        "method": "GET",
        "url": "{{gateway}}/api/incidents"
      }
    },
    {
      "name": "Notifications",
      "request": {
        "method": "GET",
        "url": "{{gateway}}/api/notifications"
      }
    },
    {
      "name": "CPU Report CSV",
      "request": {
        "method": "GET",
        "url": "{{gateway}}/api/reports/cpu.csv"
      }
    }
  ]
}
